    return f"Résume le texte suivant en une version {length} : « {title} »."

@mcp.tool
async def require_summary(title: str, ctx: Context) -> str:
    result = await ctx.get_prompt("summarize", {"title": title, "length": "short"})
    return result.messages[0].content if result.messages else ""
